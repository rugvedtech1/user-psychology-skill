{
  "id": "user-psychology-skill",
  "name": "User Psychology Skill",
  "version": "1.0.0",
  "description": "Teaches Claude user psychology principles to automatically build high-converting, psychologically optimized UI/UX. Covers CTA psychology, color theory, FOMO, social proof, pricing psychology, trust signals, and more.",
  "author": {
    "name": "rugvedtech1",
