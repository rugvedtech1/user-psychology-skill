  "category": "design",
  "tags": [
    "psychology",
    "ux",
    "ui",
    "conversion",
    "cta",
    "fomo",
    "social-proof",
    "pricing",
    "trust",
    "ecommerce",
    "saas",
    "fintech",
    "healthcare",
    "edtech"
  ],
  "entrypoint": ".claude/skills/user-psychology/SKILL.md",
  "activationFile": "CLAUDE.md",
  "autoActivate": true,
  "autoActivationTriggers": [
    "landing page",
    "homepage",
    "UI",
    "UX",
    "design",
    "interface",
    "pricing page",
