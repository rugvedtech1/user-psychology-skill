  "capabilities": {
    "readFiles": true,
    "writeFiles": false,
    "networkAccess": false,
    "runCommands": false
  },
  "skillFiles": [
    ".claude/skills/user-psychology/SKILL.md",
    "src/principles/01-cta-psychology.md",
    "src/principles/02-color-psychology.md",
    "src/principles/03-social-proof.md",
    "src/principles/04-fomo-scarcity.md",
    "src/principles/05-eye-patterns.md",
    "src/principles/06-above-fold.md",
    "src/principles/07-pricing-psychology.md",
    "src/principles/08-form-psychology.md",
    "src/principles/09-trust-signals.md",
    "src/principles/10-dark-patterns.md",
    "src/industries/ecommerce.md",
    "src/industries/saas.md",
    "src/industries/fintech.md",
    "src/industries/healthcare.md",
    "src/industries/edtech.md",
    "src/examples/amazon-analysis.md",
    "src/examples/netflix-analysis.md",
    "src/examples/spotify-analysis.md",
    "src/examples/razorpay-analysis.md",
    "src/examples/swiggy-analysis.md",
    "src/reasoning/industry-rules.md"
