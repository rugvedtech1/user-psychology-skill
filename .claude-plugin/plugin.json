  "outputFormat": {
    "requiresPsychologyDecisionsTable": true,
    "requiresABTestRecommendations": true,
    "tableColumns": [
      "Principle",
      "Applied",
      "Reason",
      "Expected Impact"
    ]
  },
  "supportedIndustries": [
    "ecommerce",
    "saas",
    "fintech",
    "healthcare",
    "edtech"
